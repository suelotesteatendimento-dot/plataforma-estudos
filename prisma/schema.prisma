generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// profiles e invite_codes são gerenciados via SQL/Supabase diretamente

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  createdById String    // auth.users(id)
  usedById    String?   // auth.users(id)
  isUsed      Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model StudyPlan {
  id          String   @id @default(cuid())
  userId      String
  title       String
  subject     String
  description String?
  studyDate   DateTime
  status      String   @default("pending") // pending | in_progress | done
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Exercise {
  id             String            @id @default(cuid())
  userId         String
  title          String            @default("")
  subject        String
  topic          String
  difficulty     String
  type           String
  language       String?
  question       String
  options        String?
  correctAnswer  String?
  expectedAnswer String?
  inputExample   String?
  outputExample  String?
  testCases      String?
  explanation    String?
  points         Int
  createdAt      DateTime          @default(now())
  attempts       ExerciseAttempt[]
  reviewLogs     ReviewLog[]
  examAnswers    ExamAnswer[]

  @@index([userId])
}

model ExerciseAttempt {
  id              String   @id @default(cuid())
  userId          String
  exerciseId      String
  exercise        Exercise @relation(fields: [exerciseId], references: [id])
  answerText      String?
  answerCode      String?
  aiFeedback      String?
  aiSummary       String?
  aiUnderstanding String?
  aiLogic         String?
  aiSyntax        String?
  aiImprovements  String?
  aiFinalVerdict  String?
  score           Int      @default(0)
  pointsAwarded   Boolean  @default(false)
  completedAt     DateTime @default(now())

  @@index([userId])
}

model DailyScore {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  totalPoints Int      @default(0)

  @@unique([date, userId])
  @@index([userId])
}

model ExamSession {
  id              String       @id @default(cuid())
  userId          String
  subject         String
  topic           String
  difficulty      String
  type            String
  totalQuestions  Int
  exerciseIds     String
  score           Int          @default(0)
  pointsEarned    Int          @default(0)
  durationMinutes Int?
  finishReason    String?      // "manual" | "time_up"
  startedAt       DateTime     @default(now())
  finishedAt      DateTime?
  answers         ExamAnswer[]

  @@index([userId])
}

model ExamAnswer {
  id             String      @id @default(cuid())
  examSessionId  String
  examSession    ExamSession @relation(fields: [examSessionId], references: [id])
  exerciseId     String
  exercise       Exercise    @relation(fields: [exerciseId], references: [id])
  answerText     String?
  answerCode     String?
  aiSummary      String?
  aiFinalVerdict String?
  score          Int         @default(0)
  createdAt      DateTime    @default(now())
}

model UserStats {
  id             String    @id @default(cuid())
  userId         String    @unique
  currentStreak  Int       @default(0)
  bestStreak     Int       @default(0)
  lastActiveDate DateTime?
  updatedAt      DateTime  @updatedAt
}

model ReviewLog {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  language   String?
  code       String?
  feedback   String?
  score      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model FlashcardSet {
  id         String   @id @default(cuid())
  userId     String
  subject    String
  topic      String
  difficulty String
  cards      String   // JSON: [{front, back}]
  createdAt  DateTime @default(now())

  @@index([userId])
}

model StudySummary {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  topic     String
  level     String
  objective String
  title     String
  content   String   // JSON: {introduction, mainContent, importantTopics, examples, commonMistakes, examTips, finalReview}
  createdAt DateTime @default(now())

  @@index([userId])
}
